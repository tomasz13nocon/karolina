{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated",
        "--executablePath",
        "/run/current-system/sw/bin/brave"
      ]
    },
    "directus": {
      "type": "http",
      "url": "http://localhost:8055/mcp",
      "headers": {
        "Authorization": "Bearer ${DIRECTUS_MCP_TOKEN}"
      }
    }
  }
}

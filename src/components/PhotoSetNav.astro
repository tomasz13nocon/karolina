---
import Link from "@components/Link.astro";
import PhotoSetDropdown from "@components/PhotoSetDropdown.astro";
import type { PhotoSection, PhotoSet } from "@lib/directus";
import { setAttr } from "@lib/visualEditing";
import { toUrl } from "@lib/util";

interface Props {
  photoSections: PhotoSection[];
}

const { photoSections } = Astro.props;

function photoSetHref(photoSet: PhotoSet) {
  return "/photography/" + toUrl(photoSet.title);
}
---

<nav class="mt-12 lg:mt-8 mb-16">
  {
    photoSections.map(({ label, displayMode, photoSets }) => {
      const sets = photoSets ?? [];

      return displayMode === "dropdown" ? (
        <PhotoSetDropdown label={label} photoSets={sets} />
      ) : (
        <ul class="flex flex-wrap justify-center">
          {sets.map((photoSet) => (
            <li class="inline-block">
              <Link
                href={photoSetHref(photoSet)}
                class="px-4 pb-4 lg:px-2 group"
                activeClass="!tracking-[0.55em] !font-bold px-6"
                data-directus={setAttr({
                  collection: "photo_sets",
                  item: photoSet.id,
                  fields: ["title"],
                  mode: "popover",
                })}
              >
                {photoSet.title}
              </Link>
            </li>
          ))}
        </ul>
      );
    })
  }
</nav>

---
import Link from "@components/Link.astro";
import type { PhotoSet } from "@lib/directus";
import { toUrl } from "@lib/util";

interface Props {
  photoSetGroups: PhotoSet[][];
}

const { photoSetGroups } = Astro.props;
---

<nav class="mt-12 lg:mt-8 mb-16">
  {
    photoSetGroups.map((photoSets) => (
      <ul class="flex flex-wrap justify-center">
        {photoSets.map((photoSet) => (
          <li class="inline-block">
            <Link
              href={"/photography/" + toUrl(photoSet.title)}
              class="px-4 pb-4 lg:px-2 group"
              activeClass="!tracking-[0.55em] !font-bold px-6"
            >
              {photoSet.title}
            </Link>
          </li>
        ))}
      </ul>
    ))
  }
</nav>

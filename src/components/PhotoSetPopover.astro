---
import Blurhash from "@components/Blurhash.astro";
import Link from "@components/Link.astro";
import { imgSrc, type PhotoSet } from "@lib/directus";
import { isCurrent, toUrl } from "@lib/util";

type PopoverVariant = "list" | "thumbnails" | "proofs";

interface Props {
  label: string | null;
  photoSets: PhotoSet[];
  variant?: PopoverVariant;
}

const { label, photoSets, variant = "list" } = Astro.props;
const pathname = Astro.url.pathname;
const normalizedLabel = label ?? "selected projects";

function photoSetHref(photoSet: PhotoSet) {
  return "/photography/" + toUrl(photoSet.title);
}

function isActive(photoSet: PhotoSet) {
  return isCurrent(photoSetHref(photoSet), pathname);
}

const active = photoSets.some(isActive);
---

<div
  class="relative mx-auto flex w-max flex-col items-center pb-4"
  data-photo-set-dropdown
  data-initial-variant={variant}
>
  <button
    type="button"
    class={`overflow-clip relative inline-block tracking-wide font-medium text-grey-3 hover:text-hover px-4 pb-4 lg:px-2 ${active ? "!tracking-[0.55em] !font-bold px-6" : ""}`}
    aria-expanded="false"
    data-photo-set-dropdown-button
  >
    {label}
  </button>

  <div class="absolute top-full z-20 w-max" data-photo-set-popover>
    <ul
      class="t-dropdown popover-menu-list flex flex-col items-stretch gap-1 bg-white px-5 pb-4 pt-3 shadow-xl"
      data-origin="top-center"
      data-photo-set-popover-variant="list"
      aria-hidden="true"
      hidden
      data-photo-set-dropdown-menu
    >
      <li
        class="mb-1 border-b border-grey-5/70 pb-2 text-center text-[0.65rem] uppercase tracking-[0.35em] text-grey-2"
      >
        {normalizedLabel}
      </li>
      {
        photoSets.map((photoSet) => (
          <li class="text-center">
            <Link
              href={photoSetHref(photoSet)}
              class="px-4 lg:px-2 group"
              activeClass="!tracking-[0.55em] !font-bold px-6"
            >
              {photoSet.title}
            </Link>
          </li>
        ))
      }
    </ul>

    <ul
      class="t-dropdown popover-menu-thumbnails flex flex-col gap-2 bg-white p-2 shadow-xl"
      data-origin="top-center"
      data-photo-set-popover-variant="thumbnails"
      aria-hidden="true"
      hidden
      data-photo-set-dropdown-menu
    >
      <li
        class="px-2 pb-1 pt-0.5 text-center text-[0.65rem] uppercase tracking-[0.35em] text-grey-2"
      >
        {normalizedLabel}
      </li>
      {
        photoSets.map((photoSet) => {
          const href = photoSetHref(photoSet);
          const active = isActive(photoSet);

          return (
            <li class="max-w-full">
              <a
                href={href}
                aria-current={active ? "page" : null}
                class:list={[
                  "max-w-full w-56 aspect-ratio-polyfill flex items-center justify-center relative overflow-clip group",
                  active && "pointer-events-none",
                ]}
                style={{
                  "--aspect-ratio": `${(1 / 2.6) * 100}%`,
                }}
              >
                <img
                  src={imgSrc(photoSet.thumbnail, {
                    width: 280,
                    height: 108,
                    format: "webp",
                    quality: 90,
                  })}
                  alt={photoSet.title + " set thumbnail"}
                  class="absolute inset-0 h-full w-full object-cover duration-500 ease-expo"
                />
                <Blurhash rawSrc={photoSet.thumbnail} />
                <div
                  class:list={[
                    "absolute inset-0 bg-black/60 opacity-0 transition-opacity duration-500 ease-expo group-hover:opacity-100",
                    active && "opacity-100",
                  ]}
                />
                <span
                  class:list={[
                    "z-10 text-grey-7 tracking-[0.2em] text-sm font-medium drop-shadow-text-1 duration-500 ease-expo transition-all group-hover:tracking-[0.5em]",
                    active && "!tracking-[0.5em] font-bold",
                  ]}
                >
                  {photoSet.title}
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>

    <ul
      class="t-dropdown popover-menu-proofs grid grid-cols-2 gap-px bg-black p-px shadow-2xl"
      data-origin="top-center"
      data-photo-set-popover-variant="proofs"
      aria-hidden="true"
      hidden
      data-photo-set-dropdown-menu
    >
      <li
        class="col-span-2 bg-black px-3 py-2 text-center text-[0.6rem] uppercase tracking-[0.42em] text-grey-5"
      >
        {normalizedLabel} / {String(photoSets.length).padStart(2, "0")} sets
      </li>
      {
        photoSets.map((photoSet, index) => {
          const href = photoSetHref(photoSet);
          const active = isActive(photoSet);
          const spansBothColumns = photoSets.length % 2 === 1 && index === photoSets.length - 1;

          return (
            <li class:list={[spansBothColumns && "col-span-2"]}>
              <a
                href={href}
                aria-current={active ? "page" : null}
                class:list={[
                  "group relative flex h-28 w-36 isolate items-center justify-center overflow-clip bg-black text-grey-7",
                  spansBothColumns && "w-full",
                  active && "pointer-events-none",
                ]}
              >
                <img
                  src={imgSrc(photoSet.thumbnail, {
                    width: spansBothColumns ? 360 : 180,
                    height: 140,
                    format: "webp",
                    quality: 90,
                  })}
                  alt={photoSet.title + " set thumbnail"}
                  class="absolute inset-0 h-full w-full object-cover grayscale opacity-45 transition-all duration-700 ease-expo group-hover:scale-110 group-hover:opacity-100"
                />
                <Blurhash rawSrc={photoSet.thumbnail} />
                <div
                  class:list={[
                    "absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-white/10 transition-opacity duration-700 ease-expo group-hover:opacity-75",
                    active && "opacity-75",
                  ]}
                />
                <span class="absolute left-2 top-2 text-[0.65rem] font-medium tracking-[0.35em] text-grey-5 opacity-70">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <span
                  class:list={[
                    "absolute inset-x-2 bottom-4 text-center text-[0.7rem] font-medium uppercase tracking-[0.25em] text-grey-7 drop-shadow-text-1 transition-all duration-700 ease-expo group-hover:tracking-[0.55em]",
                    active && "!tracking-[0.55em] font-bold",
                  ]}
                >
                  {photoSet.title}
                </span>
                <span
                  class:list={[
                    "absolute inset-x-4 bottom-3 h-px origin-left scale-x-0 bg-grey-7 transition-transform duration-700 ease-expo group-hover:scale-x-100",
                    active && "scale-x-100",
                  ]}
                />
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</div>

<style>
  :root {
    --dropdown-open-dur: 250ms;
    --dropdown-close-dur: 150ms;
    --dropdown-pre-scale: 0.97;
    --dropdown-closing-scale: 0.99;
    --dropdown-ease: cubic-bezier(0.22, 1, 0.36, 1);
  }

  .t-dropdown {
    position: relative;
    transform-origin: top left;
    transform: scale(var(--dropdown-pre-scale));
    opacity: 0;
    pointer-events: none;
    transition:
      transform var(--dropdown-open-dur) var(--dropdown-ease),
      opacity var(--dropdown-open-dur) var(--dropdown-ease);
  }

  .popover-menu-list::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -1rem;
    height: 1rem;
    width: 1px;
    background: color-mix(in srgb, var(--color-grey-3) 70%, transparent);
  }

  .popover-menu-thumbnails::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -0.42rem;
    height: 0.85rem;
    width: 0.85rem;
    background: white;
    box-shadow: -2px -2px 8px rgba(0, 0, 0, 0.04);
    transform: translateX(-50%) rotate(45deg);
  }

  .popover-menu-proofs::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -1.15rem;
    height: 1.15rem;
    width: 2px;
    background: black;
    transform: translateX(-50%);
  }

  .t-dropdown[data-origin="top-right"] {
    transform-origin: top right;
  }

  .t-dropdown[data-origin="top-center"] {
    transform-origin: top center;
  }

  .t-dropdown[data-origin="bottom-left"] {
    transform-origin: bottom left;
  }

  .t-dropdown[data-origin="bottom-center"] {
    transform-origin: bottom center;
  }

  .t-dropdown[data-origin="bottom-right"] {
    transform-origin: bottom right;
  }

  .t-dropdown.is-open {
    transform: none;
    opacity: 1;
    pointer-events: auto;
  }

  .t-dropdown.is-closing {
    transform: scale(var(--dropdown-closing-scale));
    opacity: 0;
    pointer-events: none;
    transition:
      transform var(--dropdown-close-dur) var(--dropdown-ease),
      opacity var(--dropdown-close-dur) var(--dropdown-ease);
  }

  @media (prefers-reduced-motion: reduce) {
    .t-dropdown {
      transition: none !important;
    }
  }
</style>

<script>
  const variantKey = "photoSetPopoverVariant";
  const variants = ["list", "thumbnails", "proofs"] as const;
  type Variant = (typeof variants)[number];
  const dropdowns = document.querySelectorAll<HTMLElement>("[data-photo-set-dropdown]");
  const closeDuration = 150;

  const isVariant = (value: string | null): value is Variant => {
    return variants.includes(value as Variant);
  };

  const getCurrentVariant = (fallback: string | undefined): Variant => {
    const rootVariant = document.documentElement.dataset.photoSetPopoverVariant ?? null;
    if (isVariant(rootVariant)) return rootVariant;

    const savedVariant = localStorage.getItem(variantKey);
    if (isVariant(savedVariant)) return savedVariant;

    const fallbackVariant = fallback ?? null;
    return isVariant(fallbackVariant) ? fallbackVariant : "list";
  };

  if (!isVariant(document.documentElement.dataset.photoSetPopoverVariant ?? null)) {
    const firstDropdown = dropdowns[0];
    document.documentElement.dataset.photoSetPopoverVariant = getCurrentVariant(
      firstDropdown?.dataset.initialVariant,
    );
  }

  for (const dropdown of dropdowns) {
    if (dropdown.dataset.photoSetDropdownInitialized) continue;
    dropdown.dataset.photoSetDropdownInitialized = "true";

    const button = dropdown.querySelector<HTMLButtonElement>("[data-photo-set-dropdown-button]");
    const popover = dropdown.querySelector<HTMLElement>("[data-photo-set-popover]");
    const menus = Array.from(
      dropdown.querySelectorAll<HTMLElement>("[data-photo-set-dropdown-menu]"),
    );
    let closeTimeout: ReturnType<typeof setTimeout> | undefined;

    if (!button || !popover || menus.length === 0) continue;

    const getActiveMenu = () => {
      const variant = getCurrentVariant(dropdown.dataset.initialVariant);
      return menus.find((menu) => menu.dataset.photoSetPopoverVariant === variant) ?? menus[0];
    };

    const hideInactiveMenus = (activeMenu: HTMLElement) => {
      for (const menu of menus) {
        if (menu === activeMenu) continue;

        menu.hidden = true;
        menu.setAttribute("aria-hidden", "true");
        menu.classList.remove("is-open", "is-closing");
      }
    };

    const positionPopover = (activeMenu = getActiveMenu()) => {
      popover.style.left = `${Math.round((dropdown.offsetWidth - activeMenu.offsetWidth) / 2)}px`;
    };

    const open = () => {
      const activeMenu = getActiveMenu();

      if (closeTimeout) clearTimeout(closeTimeout);
      hideInactiveMenus(activeMenu);
      activeMenu.hidden = false;
      positionPopover(activeMenu);
      activeMenu.setAttribute("aria-hidden", "false");
      activeMenu.classList.remove("is-closing");
      button.setAttribute("aria-expanded", "false");
      requestAnimationFrame(() => {
        button.setAttribute("aria-expanded", "true");
        activeMenu.classList.add("is-open");
      });
    };

    const close = () => {
      const openMenus = menus.filter((menu) => !menu.hidden);
      if (
        openMenus.length === 0 ||
        openMenus.some((menu) => menu.classList.contains("is-closing"))
      ) {
        return;
      }

      button.setAttribute("aria-expanded", "false");

      for (const menu of openMenus) {
        menu.classList.remove("is-open");
        menu.classList.add("is-closing");
        menu.setAttribute("aria-hidden", "true");
      }

      closeTimeout = setTimeout(() => {
        for (const menu of openMenus) {
          menu.hidden = true;
          menu.classList.remove("is-closing");
        }
      }, closeDuration);
    };

    const applyVariant = () => {
      const activeMenu = getActiveMenu();
      const expanded = button.getAttribute("aria-expanded") === "true";
      hideInactiveMenus(activeMenu);

      if (!expanded) return;

      activeMenu.hidden = false;
      activeMenu.setAttribute("aria-hidden", "false");
      activeMenu.classList.add("is-open");
      positionPopover(activeMenu);
    };

    button.addEventListener("click", () => {
      const expanded = button.getAttribute("aria-expanded") === "true";
      if (expanded) close();
      else open();
    });

    for (const menu of menus) {
      menu.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;

        const link = event.target.closest("a");
        if (link) close();
      });
    }

    document.addEventListener("click", (event) => {
      if (!(event.target instanceof Node)) return;
      if (
        event.target instanceof Element &&
        event.target.closest("[data-photo-set-variant-switcher]")
      ) {
        return;
      }
      if (!dropdown.contains(event.target)) close();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") close();
    });

    window.addEventListener("photoSetPopoverVariantChange", applyVariant);
    window.addEventListener("resize", () => {
      if (button.getAttribute("aria-expanded") === "true") positionPopover();
    });
  }
</script>

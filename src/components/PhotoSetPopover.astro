---
import Link from "@components/Link.astro";
import { type PhotoSet } from "@lib/directus";
import { isCurrent, toUrl } from "@lib/util";

type PopoverVariant = "popup" | "inline" | "stagger";

interface Props {
  label: string | null;
  photoSets: PhotoSet[];
  variant?: PopoverVariant;
}

const { label, photoSets, variant = "popup" } = Astro.props;
const pathname = Astro.url.pathname;

function photoSetHref(photoSet: PhotoSet) {
  return "/photography/" + toUrl(photoSet.title);
}

function isActive(photoSet: PhotoSet) {
  return isCurrent(photoSetHref(photoSet), pathname);
}

const active = photoSets.some(isActive);
---

<div
  class="relative mx-auto flex w-max flex-col items-center pb-4"
  data-photo-set-dropdown
  data-initial-variant={variant}
>
  <button
    type="button"
    class={`overflow-clip relative inline-block tracking-wide font-medium text-grey-3 hover:text-hover px-4 pb-4 lg:px-2 ${active ? "!tracking-[0.55em] !font-bold px-6" : ""}`}
    aria-expanded="false"
    data-photo-set-dropdown-button
  >
    {label}
  </button>

  <div class="absolute top-full z-20 w-max" data-photo-set-popover>
    <ul
      class="t-dropdown popover-menu-popup flex flex-col items-stretch gap-1 bg-white px-5 pb-4 pt-3 shadow-xl"
      data-origin="top-center"
      data-photo-set-popover-variant="popup"
      aria-hidden="true"
      hidden
      data-photo-set-dropdown-menu
    >
      {
        photoSets.map((photoSet) => (
          <li class="text-center">
            <Link
              href={photoSetHref(photoSet)}
              class="px-4 lg:px-2 group"
              activeClass="!tracking-[0.55em] !font-bold px-6"
            >
              {photoSet.title}
            </Link>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="popover-flow">
    <ul
      class="popover-menu-flow popover-menu-inline flex flex-col items-stretch gap-1 px-5"
      data-photo-set-popover-variant="inline"
      aria-hidden="true"
      hidden
      data-photo-set-dropdown-menu
    >
      {
        photoSets.map((photoSet) => (
          <li class="text-center">
            <Link
              href={photoSetHref(photoSet)}
              class="px-4 lg:px-2 group"
              activeClass="!tracking-[0.55em] !font-bold px-6"
            >
              {photoSet.title}
            </Link>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="popover-flow popover-flow-stagger">
    <ul
      class="popover-menu-flow popover-menu-stagger flex flex-col items-stretch gap-1 px-5"
      data-photo-set-popover-variant="stagger"
      aria-hidden="true"
      hidden
      data-photo-set-dropdown-menu
    >
      {
        photoSets.map((photoSet, index) => (
          <li class="t-stagger-line text-center" style={`--stagger-index: ${index}`}>
            <Link
              href={photoSetHref(photoSet)}
              class="px-4 lg:px-2 group"
              activeClass="!tracking-[0.55em] !font-bold px-6"
            >
              {photoSet.title}
            </Link>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  :root {
    --dropdown-open-dur: 250ms;
    --dropdown-close-dur: 150ms;
    --dropdown-pre-scale: 0.97;
    --dropdown-closing-scale: 0.99;
    --dropdown-ease: cubic-bezier(0.22, 1, 0.36, 1);

    --stagger-dur: 500ms;
    --stagger-distance: 12px;
    --stagger-stagger: 40ms;
    --stagger-blur: 5px;
    --stagger-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --stagger-expand-dur: 350ms;
    --stagger-lead: 0ms;
  }

  .t-dropdown {
    position: relative;
    transform-origin: top left;
    transform: scale(var(--dropdown-pre-scale));
    opacity: 0;
    pointer-events: none;
    transition:
      transform var(--dropdown-open-dur) var(--dropdown-ease),
      opacity var(--dropdown-open-dur) var(--dropdown-ease);
  }

  .popover-menu-popup::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -1rem;
    height: 1rem;
    width: 1px;
    background: color-mix(in srgb, var(--color-grey-3) 70%, transparent);
  }

  .popover-menu-flow {
    min-height: 0;
    overflow: hidden;
  }

  /* While the wrapper row is mid-expansion the menu is shorter than its
     content; without this the flex items compress to fit and visibly spread
     back apart as the space opens. Keeping them at natural size means the
     expansion only ever clips — content never reflows. */
  .popover-menu-flow > li,
  .popover-menu-inline::before {
    flex-shrink: 0;
  }

  /* The inline menu's content is deliberately not animated — no fade or
     scale, only the wrapper's height expansion reveals it — so the connector
     line and text stay rock-steady. The connector is drawn as flow content
     instead of an absolutely positioned overhang, so it survives the flow
     wrapper's overflow clipping. */
  .popover-menu-inline::before {
    content: "";
    align-self: center;
    height: 1rem;
    width: 1px;
    margin-bottom: 0.5rem;
    background: color-mix(in srgb, var(--color-grey-3) 70%, transparent);
  }

  .t-dropdown[data-origin="top-right"] {
    transform-origin: top right;
  }

  .t-dropdown[data-origin="top-center"] {
    transform-origin: top center;
  }

  .t-dropdown[data-origin="bottom-left"] {
    transform-origin: bottom left;
  }

  .t-dropdown[data-origin="bottom-center"] {
    transform-origin: bottom center;
  }

  .t-dropdown[data-origin="bottom-right"] {
    transform-origin: bottom right;
  }

  .t-dropdown.is-open {
    transform: none;
    opacity: 1;
    pointer-events: auto;
  }

  .t-dropdown.is-closing {
    transform: scale(var(--dropdown-closing-scale));
    opacity: 0;
    pointer-events: none;
    transition:
      transform var(--dropdown-close-dur) var(--dropdown-ease),
      opacity var(--dropdown-close-dur) var(--dropdown-ease);
  }

  /* In-flow menus expand in page flow: the wrapper's grid row grows from
     0fr to 1fr, smoothly pushing the content below it down. */
  .popover-flow {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--dropdown-open-dur) var(--dropdown-ease);
  }

  .popover-flow:has(> .is-open) {
    grid-template-rows: 1fr;
  }

  .popover-flow:has(> .is-closing) {
    transition-duration: var(--dropdown-close-dur);
  }

  .popover-flow > .is-closing {
    pointer-events: none;
  }

  /* The stagger wrapper's expansion is shorter and more front-loaded than
     the line reveals, so the lines mostly play out in already-open space —
     revealing them at the moving clip edge makes the two motions fight,
     which reads as a bounce. Raise --stagger-lead to hold the lines back
     further if the expansion ever needs to be slower. */
  .popover-flow-stagger {
    transition-duration: var(--stagger-expand-dur);
  }

  .popover-flow-stagger:has(> .is-closing) {
    transition-duration: 200ms;
  }

  .popover-menu-stagger {
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms var(--stagger-ease);
  }

  /* No connector line here; the margin gives the first line headroom to
     drop into without its ascenders clipping at the menu's top edge. */
  .popover-menu-stagger > li:first-child {
    margin-top: 0.75rem;
  }

  .popover-menu-stagger.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .popover-menu-stagger.is-closing {
    opacity: 0;
    transition: opacity 200ms ease;
  }

  /* Lines start translated up + blurred + invisible and settle downward —
     the same direction the expanding space moves, so the two motions read
     as one (sliding up against the downward expansion reads as a bounce).
     .is-open on the menu flips them to their resting state, each line held
     back by its index so the eye lands on the first line first. */
  .t-stagger-line {
    opacity: 0;
    transform: translateY(calc(-1 * var(--stagger-distance)));
    filter: blur(var(--stagger-blur));
    transition:
      opacity var(--stagger-dur) var(--stagger-ease),
      transform var(--stagger-dur) var(--stagger-ease),
      filter var(--stagger-dur) var(--stagger-ease);
    transition-delay: calc(var(--stagger-lead) + var(--stagger-stagger) * var(--stagger-index, 0));
    will-change: transform, opacity, filter;
  }

  .popover-menu-stagger.is-open .t-stagger-line {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* Exit decouples from the stagger: same fade for every line, no Y return,
     no blur — the disappearance reads as a single quiet fade instead of a
     reverse reveal. */
  .popover-menu-stagger.is-closing .t-stagger-line {
    opacity: 0;
    transform: translateY(0);
    filter: blur(0);
    transition:
      opacity 200ms ease,
      transform 0s linear,
      filter 0s linear;
    transition-delay: 0s;
  }

  @media (prefers-reduced-motion: reduce) {
    .t-dropdown,
    .popover-flow,
    .popover-menu-stagger,
    .t-stagger-line {
      transition: none !important;
    }
  }
</style>

<script>
  const variantKey = "photoSetPopoverVariant";
  const variants = ["popup", "inline", "stagger"] as const;
  type Variant = (typeof variants)[number];
  const dropdowns = document.querySelectorAll<HTMLElement>("[data-photo-set-dropdown]");
  const closeDuration = 200;

  const isVariant = (value: string | null): value is Variant => {
    return variants.includes(value as Variant);
  };

  const getCurrentVariant = (fallback: string | undefined): Variant => {
    const rootVariant = document.documentElement.dataset.photoSetPopoverVariant ?? null;
    if (isVariant(rootVariant)) return rootVariant;

    const savedVariant = localStorage.getItem(variantKey);
    if (isVariant(savedVariant)) return savedVariant;

    const fallbackVariant = fallback ?? null;
    return isVariant(fallbackVariant) ? fallbackVariant : "popup";
  };

  if (!isVariant(document.documentElement.dataset.photoSetPopoverVariant ?? null)) {
    const firstDropdown = dropdowns[0];
    document.documentElement.dataset.photoSetPopoverVariant = getCurrentVariant(
      firstDropdown?.dataset.initialVariant,
    );
  }

  for (const dropdown of dropdowns) {
    if (dropdown.dataset.photoSetDropdownInitialized) continue;
    dropdown.dataset.photoSetDropdownInitialized = "true";

    const button = dropdown.querySelector<HTMLButtonElement>("[data-photo-set-dropdown-button]");
    const popover = dropdown.querySelector<HTMLElement>("[data-photo-set-popover]");
    const menus = Array.from(
      dropdown.querySelectorAll<HTMLElement>("[data-photo-set-dropdown-menu]"),
    );
    let closeTimeout: ReturnType<typeof setTimeout> | undefined;

    if (!button || !popover || menus.length === 0) continue;

    const getActiveMenu = () => {
      const variant = getCurrentVariant(dropdown.dataset.initialVariant);
      return menus.find((menu) => menu.dataset.photoSetPopoverVariant === variant) ?? menus[0];
    };

    const hideInactiveMenus = (activeMenu: HTMLElement) => {
      for (const menu of menus) {
        if (menu === activeMenu) continue;

        menu.hidden = true;
        menu.setAttribute("aria-hidden", "true");
        menu.classList.remove("is-open", "is-closing");
      }
    };

    const positionPopover = (activeMenu = getActiveMenu()) => {
      if (!popover.contains(activeMenu)) return;
      popover.style.left = `${Math.round((dropdown.offsetWidth - activeMenu.offsetWidth) / 2)}px`;
    };

    // Forces a style/layout pass so the just-unhidden menu's start state is
    // committed before is-open lands — otherwise both changes can collapse
    // into one recalc and the open transitions never play.
    const forceReflow = (el: HTMLElement) => el.offsetHeight;

    const open = () => {
      const activeMenu = getActiveMenu();

      if (closeTimeout) clearTimeout(closeTimeout);
      hideInactiveMenus(activeMenu);
      activeMenu.hidden = false;
      positionPopover(activeMenu);
      activeMenu.setAttribute("aria-hidden", "false");
      activeMenu.classList.remove("is-closing");
      forceReflow(activeMenu);
      button.setAttribute("aria-expanded", "false");
      requestAnimationFrame(() => {
        button.setAttribute("aria-expanded", "true");
        activeMenu.classList.add("is-open");
      });
    };

    const close = () => {
      const openMenus = menus.filter((menu) => !menu.hidden);
      if (
        openMenus.length === 0 ||
        openMenus.some((menu) => menu.classList.contains("is-closing"))
      ) {
        return;
      }

      button.setAttribute("aria-expanded", "false");

      for (const menu of openMenus) {
        menu.classList.remove("is-open");
        menu.classList.add("is-closing");
        menu.setAttribute("aria-hidden", "true");
      }

      closeTimeout = setTimeout(() => {
        for (const menu of openMenus) {
          menu.hidden = true;
          menu.classList.remove("is-closing");
        }
      }, closeDuration);
    };

    const applyVariant = () => {
      const activeMenu = getActiveMenu();
      const expanded = button.getAttribute("aria-expanded") === "true";
      hideInactiveMenus(activeMenu);

      if (!expanded) return;

      activeMenu.hidden = false;
      activeMenu.setAttribute("aria-hidden", "false");
      activeMenu.classList.add("is-open");
      positionPopover(activeMenu);
    };

    button.addEventListener("click", () => {
      const expanded = button.getAttribute("aria-expanded") === "true";
      if (expanded) close();
      else open();
    });

    for (const menu of menus) {
      menu.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;

        const link = event.target.closest("a");
        if (link) close();
      });
    }

    document.addEventListener("click", (event) => {
      if (!(event.target instanceof Node)) return;
      if (
        event.target instanceof Element &&
        event.target.closest("[data-photo-set-variant-switcher]")
      ) {
        return;
      }
      if (!dropdown.contains(event.target)) close();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") close();
    });

    window.addEventListener("photoSetPopoverVariantChange", applyVariant);
    window.addEventListener("resize", () => {
      if (button.getAttribute("aria-expanded") === "true") positionPopover();
    });
  }
</script>

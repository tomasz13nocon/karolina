---
import ImageViewer from "@components/ImageViewer.astro";
import Nav from "@components/Nav.astro";
import PhotoGrid from "@components/PhotoGrid.astro";
import PhotoSetNav from "@components/PhotoSetNav.astro";
import PhotoSetPopoverVariantSwitcher from "@components/PhotoSetPopoverVariantSwitcher.astro";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import directus from "@lib/directus";
import { readItems, readSingleton } from "@directus/sdk";

// The two reads are independent — run them concurrently.
const [sections, photography] = await Promise.all([
  directus.request(
    readItems("photo_sections", {
      fields: ["id", "label", "displayMode", { photoSets: ["*"] }],
      sort: ["sort"],
      deep: { photoSets: { _sort: ["sort"] } },
    }),
  ),
  directus.request(
    readSingleton("photography", {
      fields: [{ selectedWorks: [{ directus_files_id: ["id", "width", "height"] }] }],
    }),
  ),
]);
const selectedWorks = photography.selectedWorks ?? [];
const photoSetPopoverVariant = "proofs";
---

<Layout>
  <Main class="w-full sm:!w-auto xl:w-wide flex flex-col justify-items-center">
    <Nav />
    <PhotoSetNav photoSections={sections} photoSetPopoverVariant={photoSetPopoverVariant} />

    <PhotoGrid photos={selectedWorks} dynamicPosition />
  </Main>
  <ImageViewer />
  <PhotoSetPopoverVariantSwitcher />
</Layout>

---
import Layout from "@layouts/Layout.astro";
import Nav from "@components/Nav.astro";
import ImageViewer from "@components/ImageViewer.astro";
import Main from "@layouts/Main.astro";
import { toUrl } from "@lib/util";
import PhotoSetNav from "@components/PhotoSetNav.astro";
import PhotoSetPopoverVariantSwitcher from "@components/PhotoSetPopoverVariantSwitcher.astro";
import PhotoGrid from "@components/PhotoGrid.astro";
import directus, { type PhotoSection, type PhotoSet } from "@lib/directus";
import { readItems } from "@directus/sdk";

interface Props {
  photoSet: PhotoSet;
  sections: PhotoSection[];
}

export async function getStaticPaths() {
  const [photoSets, sections] = await Promise.all([
    directus.request(
      readItems("photo_sets", {
        fields: [
          "*",
          {
            photos: ["directus_files_id", { directus_files_id: ["id", "width", "height"] }],
          },
        ],
      }),
    ),
    directus.request(
      readItems("photo_sections", {
        fields: ["id", "label", "displayMode", { photoSets: ["*"] }],
        sort: ["sort"],
        deep: { photoSets: { _sort: ["sort"] } },
      }),
    ),
  ]);

  return photoSets.map((photoSet) => ({
    params: {
      photoSet: toUrl(photoSet.title),
    },
    props: { photoSet, sections },
  }));
}

const { photoSet, sections } = Astro.props;
const photoSetPopoverVariant = "proofs";
---

<Layout>
  <Main class="sm:!w-auto xl:w-wide overflow-hidden">
    <Nav />
    <PhotoSetNav photoSections={sections} photoSetPopoverVariant={photoSetPopoverVariant} />

    {photoSet.description ? <div class="text-center mb-8" set:html={photoSet.description} /> : null}

    <PhotoGrid
      photos={photoSet.photos ?? []}
      magicGrid={photoSet.magicGrid}
      dynamicPosition={photoSet.dynamicPosition}
      maxColumns={photoSet.maxColumns}
    />
  </Main>
  <ImageViewer />
  <PhotoSetPopoverVariantSwitcher />
</Layout>

<style>
  .text-shadow {
    text-shadow: 0 0 4px black;
  }
</style>

---
import Layout from "@layouts/Layout.astro";
import Nav from "@components/Nav.astro";
import ImageViewer from "@components/ImageViewer.astro";
import Main from "@layouts/Main.astro";
import { toUrl } from "@lib/util";
import PhotoSetNav from "@components/PhotoSetNav.astro";
import PhotoGrid from "@components/PhotoGrid.astro";
import { getPhotoSetsAndSections, type PhotoSection, type PhotoSet } from "@lib/directus";
import { setAttr } from "@lib/visualEditing";

interface Props {
  photoSet: PhotoSet;
  sections: PhotoSection[];
}

export async function getStaticPaths() {
  const { photoSets, sections } = await getPhotoSetsAndSections();

  return photoSets.map((photoSet) => ({
    params: {
      photoSet: toUrl(photoSet.title),
    },
    props: { photoSet, sections },
  }));
}

// Static builds get the resolved set from getStaticPaths props. The
// server-rendered preview build skips getStaticPaths, so resolve from the URL
// param — matching either the slug (prod URLs) or the numeric id, which is what
// the Directus Live Preview URL (/photography/[id]) sends.
let photoSet: PhotoSet | undefined = Astro.props.photoSet;
let sections: PhotoSection[] = Astro.props.sections;
if (!photoSet) {
  const param = Astro.params.photoSet!;
  const data = await getPhotoSetsAndSections();
  sections = data.sections;
  photoSet = data.photoSets.find((set) => toUrl(set.title) === param || String(set.id) === param);
  if (!photoSet) return new Response(null, { status: 404 });
}
---

<Layout>
  <Main class="sm:!w-auto xl:w-wide">
    <Nav />
    <PhotoSetNav photoSections={sections} />

    <PhotoGrid
      photos={photoSet.photos ?? []}
      magicGrid={photoSet.magicGrid}
      dynamicPosition={photoSet.dynamicPosition}
      maxColumns={photoSet.maxColumns}
    />

    {
      photoSet.description ? (
        <div
          class="text-center mt-8"
          set:html={photoSet.description}
          data-directus={setAttr({
            collection: "photo_sets",
            item: photoSet.id,
            fields: ["description"],
            mode: "drawer",
          })}
        />
      ) : null
    }
  </Main>
  <ImageViewer />
</Layout>

<style>
  .text-shadow {
    text-shadow: 0 0 4px black;
  }
</style>

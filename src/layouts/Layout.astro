---
import { Font } from "astro:assets";
import directus, { imgSrc } from "../lib/directus";
import { setAttr, SINGLETON } from "../lib/visualEditing";
import { readSingleton } from "@directus/sdk";
import "../global.css";

export interface Props {
  title?: string;
}

const data = await directus.request(readSingleton("global"));

const pathLast = Astro.url.pathname.split("/").slice(-1)[0];
const title = Astro.props.title ?? "karolina nocoń" + (pathLast ? " - " + pathLast : "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- For all browsers -->
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={imgSrc(data.icon, { width: 32, format: "png" })}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href={imgSrc(data.icon, { width: 16, format: "png" })}
    />
    <!-- For Google and Android -->
    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href={imgSrc(data.icon, { width: 48, format: "png" })}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href={imgSrc(data.icon, { width: 192, format: "png" })}
    />
    <!-- For iPad -->
    <link
      rel="apple-touch-icon"
      type="image/png"
      sizes="167x167"
      href={imgSrc(data.icon, { width: 167, format: "png" })}
    />
    <!-- For iPhone -->
    <link
      rel="apple-touch-icon"
      type="image/png"
      sizes="180x180"
      href={imgSrc(data.icon, { width: 180, format: "png" })}
    />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={data.description} />
  </head>
  <body class="bg-grey-7 text-grey-1 mx-auto">
    <slot />
    <div
      id="copyright"
      class="absolute top-0 left-0 z-50 px-4 py-2 bg-grey-6 text-grey-1 select-none hidden"
      data-directus={setAttr({
        collection: "global",
        item: SINGLETON,
        fields: ["copyrightText"],
        mode: "popover",
      })}
    >
      {data.copyrightText}
    </div>
  </body>
</html>

<Font cssVariable="--font-open-sans" preload />

<script>
  import { setupCopyright } from "@lib/copyright";

  setupCopyright();
</script>

<script>
  // Click-to-edit overlays inside the Directus Studio Visual Editor. The dynamic
  // import is gated on PUBLIC_VISUAL_EDITING so the prod static build (flag
  // unset) dead-code-eliminates it and never ships the library. The iframe check
  // skips it on direct visits to the preview host — apply()'s connect handshake
  // would otherwise log a benign cross-origin postMessage warning.
  if (import.meta.env.PUBLIC_VISUAL_EDITING === "true" && window.self !== window.top) {
    import("@directus/visual-editing").then(({ apply }) => {
      apply({
        directusUrl: import.meta.env.PUBLIC_DIRECTUS_STUDIO_URL ?? "http://localhost:8055",
        onSaved: () => location.reload(),
      });
    });
  }
</script>

---
import { Font } from "astro:assets";
import directus, { imgSrc } from "../lib/directus";
import { readSingleton } from "@directus/sdk";

export interface Props {
  title?: string;
}

const data = await directus.request(readSingleton("global"));

const pathLast = Astro.url.pathname.split("/").slice(-1)[0];
const title = Astro.props.title ?? "karolina nocoń" + (pathLast ? " - " + pathLast : "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- For all browsers -->
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={imgSrc(data.icon, { width: 32, format: "png" })}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href={imgSrc(data.icon, { width: 16, format: "png" })}
    />
    <!-- For Google and Android -->
    <link
      rel="icon"
      type="image/png"
      sizes="48x48"
      href={imgSrc(data.icon, { width: 48, format: "png" })}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href={imgSrc(data.icon, { width: 192, format: "png" })}
    />
    <!-- For iPad -->
    <link
      rel="apple-touch-icon"
      type="image/png"
      sizes="167x167"
      href={imgSrc(data.icon, { width: 167, format: "png" })}
    />
    <!-- For iPhone -->
    <link
      rel="apple-touch-icon"
      type="image/png"
      sizes="180x180"
      href={imgSrc(data.icon, { width: 180, format: "png" })}
    />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={data.description} />
  </head>
  <body class="bg-grey-7 text-grey-1 mx-auto">
    <slot />
    <div
      id="copyright"
      class="absolute top-0 left-0 z-50 px-4 py-2 bg-grey-6 text-grey-1 select-none hidden"
    >
      {data.copyrightText}
    </div>
  </body>
</html>

<Font cssVariable="--font-open-sans" preload />

<style is:global>
  @import "tailwindcss";
  @config "../../tailwind.config.cjs";

  @layer base {
    html {
      font-family: var(--font-open-sans);
      font-size: 12px;
    }
    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-weight: bold;
    }
    h1 {
      font-size: 2.4em;
    }
    h2 {
      font-size: 1.5em;
    }
    h3 {
      font-size: 1.17em;
    }
    h4 {
      font-size: 1em;
    }
    h5 {
      font-size: 0.83em;
    }
    h6 {
      font-size: 0.67em;
    }
  }

  @layer utilities {
    .transition-1 {
      @apply duration-500 ease-expo;
    }
    .text-hover {
      @apply text-grey-0;
    }
    .text-hover-2 {
      @apply text-grey-3;
    }
    .aspect-ratio-polyfill:before {
      float: left;
      padding-top: var(--aspect-ratio);
      content: "";
    }
    .aspect-ratio-polyfill:after {
      display: block;
      content: "";
      clear: both;
    }
  }
</style>

<script>
  import { setupCopyright } from "@lib/copyright";

  setupCopyright();
</script>

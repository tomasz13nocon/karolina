{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--executablePath", "/run/current-system/sw/bin/brave"],
      "enabled": true
    },
    "directus": {
      "type": "remote",
      "url": "http://localhost:8055/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:DIRECTUS_MCP_TOKEN}"
      }
    }
  }
}

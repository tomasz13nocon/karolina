# Token for the Directus MCP server / local tooling (see .mcp.json).
DIRECTUS_MCP_TOKEN="your-mcp-token"

# --- docker compose (interpolated into docker-compose.yml as ${VAR}) ---
# Compose reads this file for ${...} substitution. Use plain KEY=value here (the
# DIRECTUS_MCP_TOKEN line above is `export`-prefixed for direnv/MCP only; the MCP
# var is not consumed by compose).

# Directus instance secrets.
DIRECTUS_SECRET="a-long-random-string"
DIRECTUS_ADMIN_EMAIL="you@example.com"
DIRECTUS_ADMIN_PASSWORD="change-me"

# Shared secret between Directus and the build-hook service. Compose injects it
# into BOTH containers, and Directus exposes it to flows (FLOWS_ENV_ALLOW_LIST is
# set in docker-compose.yml) so the Publish flow sends {{ $env.WEBHOOK_TOKEN }}.
WEBHOOK_TOKEN="a-long-random-string"

# Directus static token the build-hook uses to post the Studio notification when
# a build finishes (needs permission to create notifications). Optional — without
# it the build still runs, the result is just logged instead of pushed.
DIRECTUS_TOKEN="your-directus-token"

# The public origin of the Directus Studio itself, used for links Directus
# generates (and required to be a full URL since v12). Defaults to
# http://localhost:8055 for local dev; set on the prod server:
# DIRECTUS_PUBLIC_URL="https://admin.karolinanocon.com"

# Which Directus instance the frontend reads DATA from. Optional — defaults to
# http://localhost:8055, which is correct on both the dev machine and the prod
# server (Directus is co-located on both). Only set this if Directus runs
# elsewhere.
# PUBLIC_DIRECTUS_URL="http://localhost:8055"

# Where the browser loads ASSETS (images) from. You normally do NOT set this: the
# prod build (scripts/build-prod.sh) uses https://karolinanocon.com and the preview
# service (docker-compose.yml) uses https://preview.karolinanocon.com; it defaults
# to PUBLIC_DIRECTUS_URL otherwise (e.g. local dev).
# PUBLIC_ASSETS_URL="http://localhost:8055"

# --- Visual editing (Directus Studio "Visual Editor"); preview builds only ---

# The BROWSER-facing Directus Studio origin that the preview page (running inside
# the Studio's iframe) postMessages to — NOT PUBLIC_DIRECTUS_URL (that's the
# server-side data URL the browser can't reach in prod). The preview service
# (docker-compose.yml) sets this to the prod Studio; defaults to
# http://localhost:8055 for local preview.
# PUBLIC_DIRECTUS_STUDIO_URL="http://localhost:8055"

# Gates the client-side apply() script that activates click-to-edit overlays.
# Only the preview builds set it ("true"); the prod static build omits it so the
# visual-editing library is never shipped. (setAttr's data-directus attributes
# render unconditionally — they're inert strings without apply().)
# PUBLIC_VISUAL_EDITING="true"

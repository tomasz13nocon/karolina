{
  "name": "@example/basics",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "check": "astro check && tsc --noEmit && eslint . && prettier . --check",
    "fmt": "prettier . --write",
    "build": "astro build",
    "build:preview": "PUBLIC_ASSETS_URL=https://preview.karolinanocon.com MODE=preview npm run build",
    "build:prod": "PUBLIC_ASSETS_URL=https://karolinanocon.com npm run build && sudo cp -r dist /var/www/karolina/distTEMP && sudo rm -rf /var/www/karolina/dist && sudo mv /var/www/karolina/distTEMP /var/www/karolina/dist",
    "start:preview": "HOST=127.0.0.1 PORT=4322 node ./dist/server/entry.mjs",
    "preview:local": "MODE=preview npm run build && npm run start:preview",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.3",
    "@astropub/md": "^1.0.0",
    "@directus/sdk": "^21.2.2",
    "@iconify-json/ph": "^1.2.1",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.8",
    "astro-icon": "^1.1.1",
    "blurhash": "^2.0.5",
    "fast-blurhash": "^1.1.4",
    "magic-grid": "github:tomasz13nocon/Magic-Grid",
    "nanostores": "^1.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "thumbhash": "^0.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.5.0",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.0.0"
  }
}
